<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="transitops_auth_login" inherit_id="web.login" name="TransitOps Login">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="web.layout">
                <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
                <t t-set="body_classname" t-value="'o_web_client to-auth-body'"/>
                <t t-set="title" t-value="'Sign in - TransitOps'"/>
                
                <div class="to-auth">
                    <div class="to-auth__card">
                        
                        <!-- Left Panel (Branding) -->
                        <div class="to-auth__left-panel">
                            <div class="to-auth__brand">
                                <!-- Orange Building SVG Logo -->
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="to-auth__logo">
                                    <path d="M4 21H20V19H18V4H6V19H4V21ZM8 19V6H16V19H8ZM10 8H14V10H10V8ZM10 12H14V14H10V12ZM10 16H14V18H10V16Z" fill="#E87C03"/>
                                </svg>
                                <h1 class="to-auth__brand-name">TransitOps</h1>
                                <p class="to-auth__tagline">Smart Transport Operations Platform</p>
                            </div>
                            <div class="to-auth__footer">
                                <span>TRANSITOPS © 2026 • RBAC EN4</span>
                            </div>
                        </div>

                        <!-- Right Panel (Form) -->
                        <div class="to-auth__right-panel">
                            <div class="to-auth__header">
                                <h2 class="to-auth__heading">Sign in to your account</h2>
                                <p class="to-auth__subheading">Enter your credentials to continue</p>
                            </div>
                            
                            <!-- Standard Odoo Error/Message Handlers -->
                            <p class="to-auth__alert to-auth__alert--error" t-if="error" role="alert">
                                <t t-esc="error"/>
                            </p>
                            <p class="to-auth__alert to-auth__alert--success" t-if="message" role="status">
                                <t t-esc="message"/>
                            </p>

                            <!-- Auth Form -->
                            <form class="to-auth__form" role="form" t-attf-action="/web/login" method="post" onsubmit="this.action = '/web/login' + location.hash">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <!-- Email Group -->
                                <div class="to-auth__form-group">
                                    <label for="login" class="to-auth__label">EMAIL</label>
                                    <input type="text" name="login" t-att-value="login" id="login" required="required" autofocus="autofocus" autocapitalize="off" class="to-auth__input" placeholder="Enter your email"/>
                                </div>

                                <!-- Password Group -->
                                <div class="to-auth__form-group">
                                    <label for="password" class="to-auth__label">PASSWORD</label>
                                    <div class="to-auth__password-wrapper">
                                        <input type="password" name="password" id="password" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" class="to-auth__input to-auth__input--password"/>
                                        <!-- Visibility toggle hook for JS -->
                                        <button type="button" class="to-auth__password-toggle js-password-toggle" tabindex="-1">
                                            <!-- SVG icon will be injected or toggled via JS -->
                                        </button>
                                    </div>
                                </div>

                                <!-- Role Group (RBAC) -->
                                <div class="to-auth__form-group">
                                    <label for="role" class="to-auth__label">ROLE (RBAC)</label>
                                    <div class="to-auth__select-wrapper">
                                        <select name="rbac_role" id="role" class="to-auth__select" required="required">
                                            <option value="dispatcher">Dispatcher</option>
                                            <option value="admin">Admin</option>
                                            <option value="driver">Driver</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Form Actions (Remember Me & Forgot Password) -->
                                <div class="to-auth__form-actions">
                                    <label class="to-auth__remember-me">
                                        <input type="checkbox" name="remember" class="to-auth__checkbox"/>
                                        <span class="to-auth__checkbox-text">Remember me</span>
                                    </label>
                                    <a href="/web/reset_password" class="to-auth__forgot-link">Forgot password?</a>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" class="to-auth__submit-btn">Sign In</button>
                                
                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                            </form>
                        </div>

                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
