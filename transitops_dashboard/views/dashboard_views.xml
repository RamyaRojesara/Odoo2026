<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action for Dashboard -->
    <record id="action_transitops_dashboard" model="ir.actions.client">
        <field name="name">TransitOps Dashboard</field>
        <field name="tag">transitops_dashboard.main</field>
    </record>

    <!-- Top Level Menu -->
    <menuitem id="menu_transitops_root" name="TransitOps" sequence="10" web_icon="transitops_dashboard,static/description/icon.png"/>

    <!-- Dashboard Menu under Root -->
    <menuitem id="menu_transitops_dashboard" 
              name="Dashboard" 
              parent="menu_transitops_root" 
              action="action_transitops_dashboard" 
              sequence="1"/>
</odoo>
