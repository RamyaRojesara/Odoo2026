<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Maintenance Form View -->
    <record id="view_transitops_maintenance_form" model="ir.ui.view">
        <field name="name">transitops.maintenance.form</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Record">
                <header>
                    <button name="action_start" type="object" string="Start Maintenance" class="btn-primary" invisible="status != 'scheduled'" confirm="Starting maintenance will mark this vehicle as unavailable for dispatch."/>
                    <button name="action_complete" type="object" string="Complete" class="btn-success" invisible="status != 'in_progress'" confirm="Confirm work is complete and vehicle is ready?"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="status in ('completed', 'cancelled')"/>
                    
                    <field name="status" widget="statusbar" statusbar_visible="scheduled,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    
                    <group>
                        <group string="Vehicle &amp; Timing">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="date_scheduled"/>
                        </group>
                        <group string="Service Details">
                            <field name="type"/>
                            <field name="cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Work Description">
                            <field name="description" placeholder="Describe the maintenance required..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Maintenance Tree (List) View -->
    <record id="view_transitops_maintenance_tree" model="ir.ui.view">
        <field name="name">transitops.maintenance.tree</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Records" decoration-danger="type=='urgent'" decoration-info="status=='in_progress'" decoration-success="status=='completed'" decoration-muted="status=='cancelled'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="type"/>
                <field name="date_scheduled"/>
                <field name="cost" sum="Total Cost"/>
                <field name="status" widget="badge" 
                       decoration-info="status == 'in_progress'"
                       decoration-success="status == 'completed'"
                       decoration-warning="status == 'scheduled'"
                       decoration-muted="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_maintenance" model="ir.actions.client">
        <field name="name">Maintenance</field>
        <field name="tag">transitops_maintenance.registry_main</field>
    </record>

    <!-- Menu Item (Depends on Dashboard module's root menu) -->
    <menuitem id="menu_transitops_maintenance" 
              name="Maintenance" 
              parent="transitops_dashboard.menu_transitops_root" 
              action="action_transitops_maintenance" 
              sequence="50"/>

</odoo>
