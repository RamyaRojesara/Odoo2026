<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vehicle Form View -->
    <record id="view_transitops_vehicle_form" model="ir.ui.view">
        <field name="name">transitops.vehicle.form</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_available" type="object" string="Set Available" class="btn-primary" invisible="status == 'available'"/>
                    <button name="action_retire" type="object" string="Retire Vehicle" class="btn-secondary" invisible="status == 'retired'" confirm="Are you sure you want to retire this vehicle? It will be archived."/>
                    <field name="status" widget="statusbar" statusbar_visible="available,in_trip,maintenance,retired"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived (Retired)" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Registration Number"/>
                        <h1><field name="name" placeholder="e.g. AB-123-CD"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="make" placeholder="e.g. Volvo"/>
                            <field name="model" placeholder="e.g. FH16"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="capacity_kg"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vehicle Tree (List) View -->
    <record id="view_transitops_vehicle_tree" model="ir.ui.view">
        <field name="name">transitops.vehicle.tree</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles" decoration-success="status=='available'" decoration-warning="status=='maintenance'" decoration-info="status=='in_trip'" decoration-muted="status=='retired'">
                <field name="name" string="Registration No."/>
                <field name="make"/>
                <field name="model"/>
                <field name="capacity_kg"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'available'"
                       decoration-info="status == 'in_trip'"
                       decoration-warning="status == 'maintenance'"
                       decoration-muted="status == 'retired'"/>
            </tree>
        </field>
    </record>

    <!-- Vehicle Kanban View -->
    <record id="view_transitops_vehicle_kanban" model="ir.ui.view">
        <field name="name">transitops.vehicle.kanban</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="make"/>
                <field name="model"/>
                <field name="status"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_image_fill_left d-none d-md-block"
                                 t-attf-style="background-image:url('#{kanban_image('transitops.vehicle', 'image_1920', record.id.raw_value)}')"/>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="make"/> <field name="model"/>
                                </div>
                                <div>
                                    Capacity: <field name="capacity_kg"/> KG
                                </div>
                                <div class="mt-2">
                                    <field name="status" widget="label_selection" options="{'classes': {'available': 'success', 'in_trip': 'info', 'maintenance': 'warning', 'retired': 'default'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_vehicle" model="ir.actions.client">
        <field name="name">Vehicles</field>
        <field name="tag">transitops_vehicle.registry_main</field>
    </record>

    <!-- Menu Item (Depends on Dashboard module's root menu) -->
    <!-- Assuming menu_transitops_root is defined in transitops_dashboard -->
    <!-- We will redefine it here safely just in case it is installed independently, or use a cross-module reference -->
    <!-- Safe approach: redefine parent menu if it doesn't exist, but we assume dependencies handle it -->
    <menuitem id="menu_transitops_vehicle" 
              name="Vehicles" 
              parent="transitops_dashboard.menu_transitops_root" 
              action="action_transitops_vehicle" 
              sequence="20"/>

</odoo>
